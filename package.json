{
  "name": "chitvault",
  "version": "3.0.12",
  "description": "Professional Digital Ledger for Auction Chit Fund Management",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "build:electron": "cross-env ELECTRON_BUILD=1 next build",
    "build:electron:win": "cross-env ELECTRON_BUILD=1 next build && cd electron && npm install --no-audit --no-fund --silent && npm run build:win",
    "electron:dev": "cd electron && npm start"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.103.3",
    "@tanstack/react-query": "^5.99.2",
    "@types/papaparse": "^5.5.2",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.8.0",
    "next": "16.2.4",
    "papaparse": "5.5.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "cross-env": "10.1.0",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.10",
    "supabase": "2.92.1",
    "tailwindcss": "3.4.4",
    "typescript": "6.0.3"
  }
}
