{
  "name": "chitvault",
  "version": "3.0.3",
  "description": "Auction Chit Fund Management Software",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "build:electron": "cross-env ELECTRON_BUILD=1 next build",
    "build:electron:win": "cross-env ELECTRON_BUILD=1 next build && cd electron && npm install --no-audit --no-fund --silent && npm run build:win",
    "electron:dev": "cd electron && npm start"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/papaparse": "^5.5.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^1.7.0",
    "next": "15.1.9",
    "papaparse": "^5.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@types/recharts": "^1.8.29",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "supabase": "^2.84.4",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
